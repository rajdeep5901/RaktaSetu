*.db-wal
*.db-shm

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store

# ---------------------------------------------------------------------------
# Explicitly tracked (do NOT ignore)
# ---------------------------------------------------------------------------
!.env.example
!Dataset.csv
!donor_rf_model.joblib
!requirements.txt
