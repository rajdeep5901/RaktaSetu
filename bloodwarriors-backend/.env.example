# ============================================================
# RaktaSetu AI -- Environment Configuration Template
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- AI Engine Toggle ---
# True  = fully offline mock responses (no API key needed)
# False = live Groq API calls (requires valid GROQ_API_KEY)
USE_MOCK_AI=True

# --- Groq Free Tier API ---
# Sign up free at: https://console.groq.com
# Get your API key at: https://console.groq.com/keys
# Free tier: 30 req/min, 14,400 req/day (llama3-8b-8192)
GROQ_API_KEY="your_free_groq_api_key_here"

# --- Database ---
# Production: set DATABASE_URL to a managed PostgreSQL connection string
# (Neon or Supabase). When set, the app uses PostgreSQL and ignores the
# SQLite paths below. Leave it unset/commented to fall back to local SQLite.
#
#   Neon:     postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
#   Supabase: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# DATABASE_URL="postgresql://user:password@host.neon.tech/raktasetu?sslmode=require"

# --- Local SQLite fallback (used only when DATABASE_URL is unset) ---
SQLITE_DB_PATH="data/raktasetu.db"
KUZU_DB_PATH="data/kuzu_db"

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- CORS ---
# Production: comma-separated list of allowed frontend origins.
# Leave unset in development to fall back to "*" (allow any origin).
# ALLOWED_ORIGINS="https://raktasetu-frontend.onrender.com,https://raktasetu.vercel.app"
